FROM ubuntu:22.04

# Install necessary packages
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    wget \
    curl \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Set up environment variables
ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    DEBIAN_FRONTEND=noninteractive

# Create a working directory
WORKDIR /workspace

# Copy core scripts
COPY core/ /usr/local/bin/core/
RUN chmod +x /usr/local/bin/core/*.sh

# Copy plugin scripts
COPY plugins/ /usr/local/bin/plugins/
RUN chmod +x /usr/local/bin/plugins/*.sh

# Copy library scripts
COPY lib/ /usr/local/bin/lib/
RUN chmod +x /usr/local/bin/lib/*.sh

# Copy Docker Compose template
COPY docker-compose.template.yml /usr/local/bin/

# Set the entrypoint
ENTRYPOINT ["/usr/local/bin/core/env_core.sh"]