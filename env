#!/bin/bash
#
# Yocto/Poky Build Environment Setup (Modular Plugin System)
#
# This script sets up a containerized Yocto build environment using Docker
# with a modular plugin-based architecture for better maintainability.
#
# CONTAINER RUNTIME NOTES:
# - Docker Desktop: Fast volume mounts, automatic permission handling, GUI management
# - Colima: Free, open-source Docker-compatible runtime, lightweight and fast
#
# USAGE:
#   source ./docker-yocto-env-1/env
#

# Prevent direct execution
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "This script should be sourced, not executed."
    echo "Use: source ${BASH_SOURCE[0]}"
    exit 1
fi

thisFile="${BASH_SOURCE[0]}"

# Zsh support:
[ -z "${thisFile}" ] && thisFile="${(%):-%x}"
# Unsupported shell
[ -z "${thisFile}" ] && echo "Shell is unsupported" && exit 1

SCRIPT_DIR=$(dirname $(realpath "${thisFile}"))

# Export SCRIPT_DIR so plugins can access it
export SCRIPT_DIR

# Set the architecture of the environment
# Priorities:
# 1. First argument to the script
# 2. ENV_ARCH environment variable
# 3. uname -m
ENV_ARCH=${1:-${ENV_ARCH:-$(uname -m)}}

# Choose how to retrieve poky-vde image: build or pull
# PULL_VDE environment variable (build by default)
if [[ "${PULL_VDE}" == "true" ]]; then
    echo "Pulling poky-vde image"
else
    echo "Building poky-vde image with host UID/GID"
fi

# Load core system
if ! source "${SCRIPT_DIR}/core/env_core.sh"; then
    echo "ERROR: Failed to load core environment" >&2
    return 1
fi

# Initialize environment
if ! _initialize_environment; then
    echo "ERROR: Failed to initialize environment" >&2
    return 1
fi

echo
echo "This environment has the following functions:"
echo "============================================"

# Show plugin commands dynamically
show_plugin_commands

echo